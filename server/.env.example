# Application Setup
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/theralign

# Authentication
JWT_SECRET=your_jwt_secret_minimum_32_characters_long_here
JWT_EXPIRY=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Cloudinary (Phase 3 — File Uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (Phase 6 — Payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# AI Integration (Phase 8) — Free tier: https://console.groq.com
GROQ_API_KEY=

# Email Configurations (Feature F1 & Production SMTP)
EMAIL_HOST=                # Optional: e.g. smtp.resend.com, smtp.sendgrid.net (defaults to Gmail if blank)
EMAIL_PORT=465             # Optional: e.g. 465 (SSL/TLS) or 587 (STARTTLS)
EMAIL_SECURE=true          # Optional: set to 'false' if using port 587
EMAIL_USER=your_email_address@domain.com
EMAIL_PASS=your_smtp_password_or_app_password
EMAIL_FROM="Theralign <your_verified_sender@domain.com>"

